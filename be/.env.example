# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/cinema

SEED_RESET=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=tnc-cinema-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Email (BullMQ email worker)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=no-reply@tnc-cinema.com
