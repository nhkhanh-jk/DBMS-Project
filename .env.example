FLASK_ENV=development
SECRET_KEY=change-this-secret

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.<cluster-id>.mongodb.net/CinemaManagement?retryWrites=true&w=majority
MONGO_DB_NAME=CinemaManagement

REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300

JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_EXPIRES_HOURS=24

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS allowlist (comma-separated)
# Local FE first, then add real frontend domains when deployed.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
